{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Upload to GitHub",
      "type": "shell",
      "command": "${workspaceFolder}\\upload.bat",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/c"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
